    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nconst data = $json;\n\nconst battery_percentage = data.output.battery_percentage;\nconst full_range_km = data.output.full_range_km;\nconst distance_km = data.distance_km;\n\nconst remaining_range_km =\n(full_range_km * battery_percentage) / 100;\n\nconst can_reach_without_charging =\nremaining_range_km >= distance_km;\n\nreturn [{\n  json: {\n    vehicle_model: data.output.vehicle_model,\n    battery_percentage: data.output.battery_percentage,\n    current_location: data.output.current_location,\n    destination: data.output.destination,\n\n    battery_capacity_kwh: data.output.battery_capacity_kwh,\n    full_range_km: data.output.full_range_km,\n    charging_type: data.output.charging_type,\n\n    distance_km: data.distance_km,\n    duration_hours: data.duration_hours,\n\n    remaining_range_km: Math.round(remaining_range_km),\n\n    can_reach_without_charging: can_reach_without_charging\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
