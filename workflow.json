      ],
      "id": "b7679fee-db89-4fdc-a556-6230df95f2fa",
      "name": "making json data"
    },
    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nconst stations = $json.elements || [];\n\nconst trip = $('Merge1').first().json;\n\nreturn [{\n  json: {\n    trip: {\n      vehicle_model: trip.vehicle_model,\n      battery_percentage: trip.battery_percentage,\n      current_location: trip.current_location,\n      destination: trip.destination,\n      battery_capacity_kwh: trip.battery_capacity_kwh,\n      full_range_km: trip.full_range_km,\n      charging_type: trip.charging_type,\n      distance_km: trip.distance_km,\n      duration_hours: trip.duration_hours,\n      remaining_range_km: trip.remaining_range_km,\n      can_reach_without_charging: trip.can_reach_without_charging,\n      origin_lat: trip.origin_lat,\n      origin_lon: trip.origin_lon,\n      destination_lat: trip.destination_lat,\n      destination_lon: trip.destination_lon\n    },\n\n    stations: stations.map(station => ({\n      station_name: station.tags?.name || \"Unknown Charger\",\n      operator: station.tags?.operator || \"Unknown\",\n      station_lat: station.lat,\n      station_lon: station.lon,\n      tags: station.tags\n    }))\n  }\n}];"
      },
