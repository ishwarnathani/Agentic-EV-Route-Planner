    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nconst search_radius_km = $json.distance_km / 2;\n\nconst query = `\n[out:json];\n(\n  node[\"amenity\"=\"charging_station\"]\n  (around:${search_radius_km * 1000},\n  ${$json.midpoint_lat},\n  ${$json.midpoint_lon});\n);\nout body;\n`;\n\nreturn [{\n  json: {\n    ...$json,\n    overpass_query: query\n  }\n}];"
